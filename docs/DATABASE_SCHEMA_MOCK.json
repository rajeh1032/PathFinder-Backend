{
  "project": "PathFinder AI",
  "database": "Supabase PostgreSQL",
  "storage": "Supabase Storage",
  "tables": {
    "roles": ["id", "name", "description", "is_system_role", "created_at", "updated_at"],
    "users": ["id", "name", "email", "role_id", "is_active", "last_login_at", "last_active_at", "created_at", "updated_at"],
    "profiles": ["id", "user_id", "education_level", "university", "major", "current_status", "experience_level", "target_career_id", "location", "created_at", "updated_at"],
    "skills": ["id", "name", "category", "level", "aliases", "is_active", "created_by", "updated_by", "created_at", "updated_at"],
    "user_skills": ["id", "user_id", "skill_id", "level", "created_at"],
    "career_paths": ["id", "title", "description", "category", "average_salary", "difficulty_level", "is_active", "created_by", "updated_by", "created_at", "updated_at"],
    "career_path_skills": ["id", "career_path_id", "skill_id", "required_level", "priority"],
    "courses": ["id", "title", "provider", "url", "thumbnail_url", "video_url", "level", "duration", "category", "is_active", "created_by", "updated_by", "created_at", "updated_at"],
    "course_skills": ["id", "course_id", "skill_id", "created_at"],
    "cvs": ["id", "user_id", "file_url", "storage_path", "original_name", "mime_type", "size_bytes", "parsed_text", "status", "uploaded_at", "created_at", "updated_at"],
    "cv_skills": ["id", "cv_id", "skill_id", "source", "created_at"],
    "cv_analyses": ["id", "cv_id", "score", "model", "summary", "strengths", "weaknesses", "suggestions", "detected_skills", "extracted", "generated_by_type", "status", "reviewed_by_admin_id", "created_at", "reviewed_at"],
    "roadmaps": ["id", "user_id", "career_path_id", "title", "description", "progress", "status", "generated_by_type", "created_at", "updated_at"],
    "roadmap_steps": ["id", "roadmap_id", "skill_id", "title", "description", "step_order", "progress", "is_completed", "completed_at"],
    "jobs": ["id", "title", "company", "location", "description", "source", "source_type", "external_id", "apply_url", "required_skills", "employment_type", "salary_range", "is_active", "status", "created_by", "updated_by", "posted_at", "created_at", "updated_at"],
    "saved_jobs": ["id", "user_id", "job_id", "created_at"],
    "applied_jobs": ["id", "user_id", "job_id", "status", "applied_at", "created_at", "updated_at"],
    "job_matches": ["id", "user_id", "job_id", "cv_id", "match_percentage", "matched_skills", "missing_skills", "ai_reason", "generated_by_type", "status", "created_at"],
    "chat_sessions": ["id", "user_id", "title", "status", "created_at", "updated_at"],
    "chat_messages": ["id", "session_id", "sender", "message", "tokens", "created_at"],
    "interview_sessions": ["id", "user_id", "career_path_id", "job_id", "status", "overall_score", "score_breakdown", "feedback_text", "recording_url", "created_at", "updated_at"],
    "interview_questions": ["id", "interview_session_id", "question", "user_answer", "feedback", "score", "generated_by_type"],
    "cover_letters": ["id", "user_id", "job_id", "content", "status", "version", "language", "generated_by_type", "created_at", "updated_at"],
    "cover_letter_versions": ["id", "cover_letter_id", "content", "version", "edited_by_user", "created_at"],
    "ai_logs": ["id", "user_id", "feature", "model", "prompt", "response", "tokens_used", "latency_ms", "cost", "status", "error_message", "request_payload", "response_payload", "created_at"],
    "rag_documents": ["id", "title", "type", "source", "content", "storage_path", "vector_id", "index_status", "index_error", "is_active", "uploaded_by", "created_at", "updated_at"],
    "rag_chunks": ["id", "rag_document_id", "content", "chunk_index", "token_count", "vector_id", "embedding", "metadata", "created_at"],
    "api_sources": ["id", "name", "provider", "base_url", "type", "schedule_cron", "enabled", "is_active", "last_sync_at", "created_by", "updated_by", "created_at", "updated_at"],
    "api_sync_runs": ["id", "api_source_id", "started_at", "finished_at", "status", "raw_response_count", "jobs_added", "jobs_updated", "jobs_rejected", "error_message"],
    "system_settings": ["id", "setting_key", "setting_value", "type", "description", "updated_by", "updated_at"],
    "notification_settings": ["id", "user_id", "push_enabled", "email_enabled", "job_alerts_enabled", "roadmap_reminders_enabled", "interview_reminders_enabled", "ai_tips_enabled", "created_at", "updated_at"],
    "activity_logs": ["id", "admin_user_id", "action", "module", "target_id", "target_type", "old_data", "new_data", "ip_address", "user_agent", "status", "created_at"]
  },
  "relationships": [
    {"from": "roles.id", "to": "users.role_id", "type": "one_to_many"},
    {"from": "users.id", "to": "profiles.user_id", "type": "one_to_one"},
    {"from": "career_paths.id", "to": "profiles.target_career_id", "type": "one_to_many"},
    {"from": "users.id", "to": "user_skills.user_id", "type": "one_to_many"},
    {"from": "skills.id", "to": "user_skills.skill_id", "type": "one_to_many"},
    {"from": "cvs.id", "to": "cv_skills.cv_id", "type": "one_to_many"},
    {"from": "skills.id", "to": "cv_skills.skill_id", "type": "one_to_many"},
    {"from": "career_paths.id", "to": "career_path_skills.career_path_id", "type": "one_to_many"},
    {"from": "skills.id", "to": "career_path_skills.skill_id", "type": "one_to_many"},
    {"from": "courses.id", "to": "course_skills.course_id", "type": "one_to_many"},
    {"from": "skills.id", "to": "course_skills.skill_id", "type": "one_to_many"},
    {"from": "users.id", "to": "cvs.user_id", "type": "one_to_many"},
    {"from": "cvs.id", "to": "cv_analyses.cv_id", "type": "one_to_one"},
    {"from": "users.id", "to": "roadmaps.user_id", "type": "one_to_many"},
    {"from": "career_paths.id", "to": "roadmaps.career_path_id", "type": "one_to_many"},
    {"from": "roadmaps.id", "to": "roadmap_steps.roadmap_id", "type": "one_to_many"},
    {"from": "skills.id", "to": "roadmap_steps.skill_id", "type": "one_to_many"},
    {"from": "users.id", "to": "saved_jobs.user_id", "type": "one_to_many"},
    {"from": "jobs.id", "to": "saved_jobs.job_id", "type": "one_to_many"},
    {"from": "users.id", "to": "applied_jobs.user_id", "type": "one_to_many"},
    {"from": "jobs.id", "to": "applied_jobs.job_id", "type": "one_to_many"},
    {"from": "users.id", "to": "job_matches.user_id", "type": "one_to_many"},
    {"from": "jobs.id", "to": "job_matches.job_id", "type": "one_to_many"},
    {"from": "cvs.id", "to": "job_matches.cv_id", "type": "one_to_many"},
    {"from": "users.id", "to": "chat_sessions.user_id", "type": "one_to_many"},
    {"from": "chat_sessions.id", "to": "chat_messages.session_id", "type": "one_to_many"},
    {"from": "users.id", "to": "interview_sessions.user_id", "type": "one_to_many"},
    {"from": "career_paths.id", "to": "interview_sessions.career_path_id", "type": "one_to_many"},
    {"from": "jobs.id", "to": "interview_sessions.job_id", "type": "one_to_many"},
    {"from": "interview_sessions.id", "to": "interview_questions.interview_session_id", "type": "one_to_many"},
    {"from": "users.id", "to": "cover_letters.user_id", "type": "one_to_many"},
    {"from": "jobs.id", "to": "cover_letters.job_id", "type": "one_to_many"},
    {"from": "cover_letters.id", "to": "cover_letter_versions.cover_letter_id", "type": "one_to_many"},
    {"from": "users.id", "to": "ai_logs.user_id", "type": "one_to_many"},
    {"from": "rag_documents.id", "to": "rag_chunks.rag_document_id", "type": "one_to_many"},
    {"from": "api_sources.id", "to": "api_sync_runs.api_source_id", "type": "one_to_many"},
    {"from": "users.id", "to": "notification_settings.user_id", "type": "one_to_one"},
    {"from": "users.id", "to": "activity_logs.admin_user_id", "type": "one_to_many"}
  ],
  "storageBuckets": [
    {"name": "cvs", "public": false},
    {"name": "profile-images", "public": true},
    {"name": "interview-recordings", "public": false},
    {"name": "rag-documents", "public": false}
  ],
  "moduleOwnership": {
    "auth": {"owns": ["users", "roles"], "reads": ["profiles", "notification_settings"]},
    "profiles": {"owns": ["profiles"], "reads": ["users", "career_paths"]},
    "skills": {"owns": ["skills", "user_skills"], "reads": ["courses", "jobs", "career_paths"]},
    "careerPaths": {"owns": ["career_paths", "career_path_skills"], "reads": ["skills", "courses"]},
    "courses": {"owns": ["courses", "course_skills"], "reads": ["skills", "career_paths"]},
    "cvs": {"owns": ["cvs", "cv_skills"], "reads": ["skills", "cv_analyses"]},
    "cvAnalyses": {"owns": ["cv_analyses"], "reads": ["cvs", "skills", "ai_logs"]},
    "jobs": {"owns": ["jobs"], "reads": ["skills", "api_sync_runs"]},
    "savedJobs": {"owns": ["saved_jobs"], "reads": ["jobs"]},
    "appliedJobs": {"owns": ["applied_jobs"], "reads": ["jobs"]},
    "jobMatches": {"owns": ["job_matches"], "reads": ["jobs", "cvs", "cv_analyses", "skills", "user_skills"]},
    "roadmaps": {"owns": ["roadmaps", "roadmap_steps"], "reads": ["career_paths", "skills", "courses"]},
    "interviews": {"owns": ["interview_sessions", "interview_questions"], "reads": ["jobs", "career_paths", "ai_logs"]},
    "coverLetters": {"owns": ["cover_letters", "cover_letter_versions"], "reads": ["jobs", "profiles", "cv_analyses", "ai_logs"]},
    "chat": {"owns": ["chat_sessions", "chat_messages"], "reads": ["rag_documents", "rag_chunks", "ai_logs"]},
    "notifications": {"owns": ["notification_settings"], "reads": ["users"]},
    "ai": {"owns": ["ai_logs"], "reads": ["feature_specific_tables"]},
    "rag": {"owns": ["rag_documents", "rag_chunks"], "reads": ["ai_logs"]},
    "apiSources": {"owns": ["api_sources", "api_sync_runs"], "reads": ["jobs"]},
    "settings": {"owns": ["system_settings"], "reads": ["users"]},
    "activityLogs": {"owns": ["activity_logs"], "reads": ["users"]}
  }
}
